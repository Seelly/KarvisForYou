# ============ Karvis 环境变量配置 ============
# 复制此文件为 .env（项目根目录），填入真实值后使用。
# 标注 [必填] 的项必须配置，[可选] 的项可以留空。
# 留空 OneDrive 相关配置 = 自动启用 Lite 本地模式。

# --- DeepSeek API [必填] ---
# 方式一(推荐): 腾讯云知识引擎 lkeap https://console.cloud.tencent.com/lkeap
#   国内网络稳定，无需翻墙，开通即用
#   DEEPSEEK_BASE_URL=https://api.lkeap.cloud.tencent.com/v1
# 方式二: DeepSeek 官方 https://platform.deepseek.com/
#   DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 方式三: 任何兼容 OpenAI API 的平台，修改 BASE_URL 即可
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.lkeap.cloud.tencent.com/v1
DEEPSEEK_MODEL=deepseek-v3-0324

# --- Qwen Flash API [可选，留空则降级到 DeepSeek] ---
# 注册: https://bailian.console.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus-latest
QWEN_VL_MODEL=qwen-vl-max

# --- OneDrive [可选，留空 = Lite 本地模式] ---
# Lite 模式: 笔记保存在项目根目录 my_life/ 文件夹
# OneDrive 模式: 笔记自动同步到 Obsidian Vault
# 配置教程见 README.md「OneDrive 配置」章节
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REFRESH_TOKEN=

# --- 企业微信 [可选，启用企微渠道时必填] ---
# 管理后台: https://work.weixin.qq.com/wework_admin/frame
WEWORK_CORP_ID=
WEWORK_AGENT_ID=
WEWORK_CORP_SECRET=
WEWORK_TOKEN=
WEWORK_ENCODING_AES_KEY=
# 管理员企微 user_id（用于告警推送，可选）
ADMIN_WEWORK_USER_ID=

# --- 腾讯云 ASR [可选，语音识别] ---
TENCENT_APPID=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# --- Obsidian Vault 路径 ---
# OneDrive 模式: OneDrive 上的相对路径
# Lite 模式: 此值仅用于路径映射，保持默认即可
OBSIDIAN_BASE=/应用/remotely-save/EmptyVault

# --- 心知天气 [可选] ---
SENIVERSE_KEY=
WEATHER_CITY=深圳

# --- 默认管理员配置 ---
# 已废弃，请使用 ADMIN_WEWORK_USER_ID / TELEGRAM_ADMIN_CHAT_ID / FEISHU_ADMIN_OPEN_ID
# 向后兼容：若未设置 ADMIN_WEWORK_USER_ID 则回退读取此值
# ADMIN_USER_ID=

# --- 异步处理端点 ---
# 本地运行: 保持默认 http://127.0.0.1:9000/process
# SCF 部署: 填写云函数的公网 URL
PROCESS_ENDPOINT_URL=http://127.0.0.1:9000/process

# --- 多用户管理 [KarvisForAll 新增] ---
# 管理员 Web 令牌（用于访问管理页面，请设置一个长随机字符串）
ADMIN_TOKEN=your-admin-secret-token
# 每用户每日消息上限（防止 LLM 成本失控）
DAILY_MESSAGE_LIMIT=50
# Web 查看令牌有效时长（小时）
WEB_TOKEN_EXPIRE_HOURS=24
# 数据目录（留空使用默认值 ./data）
# DATA_DIR=/app/data
# 不活跃天数阈值（超过此天数的用户不触发定时任务）
# INACTIVE_DAYS_THRESHOLD=7
# Web 查看页面域名（用于生成令牌链接，如 https://your-domain.com）
# WEB_DOMAIN=

# --- 飞书 Bot [可选] ---
# 飞书开放平台: https://open.feishu.cn/
# 创建企业自建应用后获取 App ID / App Secret
# 长连接模式不需要 Verification Token 和公网回调地址
# 在飞书开放平台「事件订阅」中选择「使用长连接接收事件」
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 管理员飞书 open_id（用于告警推送，可选）
FEISHU_ADMIN_OPEN_ID=
# 飞书待办清单id （用于同步待办，可选）
FEISHU_DRIVE_ROOT_FOLDER_TOKEN=

# --- 飞书云空间 [可选，storage_mode=feishu 时需要] ---
# 将笔记同步到飞书云空间，在飞书客户端中直接查看和编辑
# 可复用上方飞书 Bot 的 App ID / App Secret
# root_folder_token: 在飞书客户端创建一个文件夹作为数据根目录，从 URL 中获取 folder token
#   例如 https://xxx.feishu.cn/drive/folder/xxxTOKENxxx → xxxTOKENxxx 即为 token
# 需要的飞书应用权限（在开放平台「权限管理」中开通）：
#   - drive:drive          — 云空间基础能力
#   - drive:file:read_write  — 读写文件
#   - drive:folder:read_write — 读写文件夹（创建目录结构）
FEISHU_DRIVE_ROOT_FOLDER_TOKEN=

# --- 渠道控制 [必填] ---
# 可选值: wework, telegram, feishu（多个用逗号分隔）
# 默认不启用任何渠道，必须显式配置
ACTIVE_CHANNELS=wework

# --- 主动陪伴参数 [可选，有默认值] ---
# COMPANION_SILENT_HOURS=4
# COMPANION_INTERVAL_HOURS=4
# COMPANION_MAX_DAILY=3
# COMPANION_RECENT_HOURS=2
